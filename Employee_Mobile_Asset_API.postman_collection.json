{
	"info": {
		"_postman_id": "employee-mobile-api-v1",
		"name": "Employee Mobile App - Asset Management API",
		"description": "Mobile API collection for employees to manage their asset assignments through the mobile app.\n\n## Features:\n- Employee dashboard with asset statistics\n- View pending asset assignments\n- Approve or reject asset assignments\n- View current assets assigned to employee\n- Request asset returns\n- Assignment history tracking\n- Push notifications management\n\n## Authentication:\nAll endpoints require Bearer token authentication via Laravel Sanctum.\nEmployees must be authenticated to access their personal asset data.\n\n## Base URL:\nUpdate the {{base_url}} variable with your tenant domain.\nExample: https://company.yourdomain.com\n\n## Mobile App Flow:\n1. Employee logs in and gets auth token\n2. Dashboard shows overview of assets and pending actions\n3. Employee can respond to pending assignments\n4. Employee can view current assets and request returns\n5. Notifications keep employee updated on assignment status",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "employee-mobile-api-v1"
	},
